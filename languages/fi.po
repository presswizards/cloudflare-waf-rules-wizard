msgstr "Mukautetut käyttäjäagentit:"

#: cloudflare_waf_rules_wizard.php:237
msgid ""
"Enter one User Agent per line. Only alphanumeric characters, spaces, underscores, "
"and hyphens are allowed."
msgstr ""
"Syötä yksi käyttäjäagentti per rivi. Vain aakkosnumeeriset merkit, välilyönnit, "
"alaviivat ja yhdysmerkit ovat sallittuja."

#: cloudflare_waf_rules_wizard.php:238
msgid "Enter one User Agent per line"
msgstr "Syötä yksi käyttäjäagentti per rivi"

#: cloudflare_waf_rules_wizard.php:317
msgid "Please enter all the required fields."
msgstr "Ole hyvä ja täytä kaikki vaaditut kentät."

