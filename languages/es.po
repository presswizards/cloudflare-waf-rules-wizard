msgid ""
"Enter one User Agent per line. Only alphanumeric characters, spaces, "
"underscores, and hyphens are allowed."
msgstr ""
"Introduce un Agente de Usuario por línea. Solo se permiten caracteres "
"alfanuméricos, espacios, guiones bajos y guiones."

#: cloudflare_waf_rules_wizard.php:238
msgid "Enter one User Agent per line"
msgstr "Introduce un Agente de Usuario por línea"

#: cloudflare_waf_rules_wizard.php:317
msgid "Please enter all the required fields."
msgstr "Por favor, introduce todos los campos requeridos."

