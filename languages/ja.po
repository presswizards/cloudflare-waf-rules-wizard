msgid "Failed to create ruleset for domain:"
msgstr "ドメインのルールセットの作成に失敗しました："

#: cloudflare_waf_rules_wizard.php:428
msgid "Successfully updated ruleset for domain:"
msgstr "ドメインのルールセットが正常に更新されました："

#: cloudflare_waf_rules_wizard.php:430
msgid "Unknown error"
msgstr "不明なエラー"

#: cloudflare_waf_rules_wizard.php:431
msgid "Failed to update ruleset for domain:"
msgstr "ドメインのルールセットの更新に失敗しました："

#: cloudflare_waf_rules_wizard.php:431
msgid "Error:"
msgstr "エラー："
