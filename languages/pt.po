msgid "Custom User Agents:"
msgstr "Agentes de Usuário Personalizados:"

#: cloudflare_waf_rules_wizard.php:237
msgid ""
"Enter one User Agent per line. Only alphanumeric characters, spaces, underscores, "
"and hyphens are allowed."
msgstr ""
"Insira um Agente de Usuário por linha. Apenas caracteres alfanuméricos, espaços, "
"sublinhados e hífens são permitidos."

#: cloudflare_waf_rules_wizard.php:238
msgid "Enter one User Agent per line"
msgstr "Insira um Agente de Usuário por linha"

#: cloudflare_waf_rules_wizard.php:317
msgid "Please enter all the required fields."
msgstr "Por favor, preencha todos os campos obrigatórios."

