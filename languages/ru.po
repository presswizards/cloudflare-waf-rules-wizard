msgstr "Введите один User Agent на строку. Допускаются только буквенно-цифровые символы, пробелы, подчеркивания и дефисы."

#: cloudflare_waf_rules_wizard.php:238
msgid "Enter one User Agent per line"
msgstr "Введите один User Agent на строку"

